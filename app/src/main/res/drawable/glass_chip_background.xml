<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked State (Active) -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#3322D3EE" /> <!-- 20% accent_cyan -->
            <corners android:radius="16dp" />
            <stroke android:width="2px" android:color="#22D3EE" /> <!-- Full glow border -->
        </shape>
    </item>
    
    <!-- Default State (Inactive) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" /> <!-- 5% white (subtle glass) -->
            <corners android:radius="16dp" />
            <stroke android:width="1px" android:color="#26FFFFFF" /> <!-- 15% white border -->
        </shape>
    </item>
</selector>
