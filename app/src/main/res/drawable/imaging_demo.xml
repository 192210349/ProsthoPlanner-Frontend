<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F172A" />
        </shape>
    </item>
    <!-- Simple placeholder circles to represent a CT scan axial view -->
    <item
        android:bottom="40dp"
        android:left="40dp"
        android:right="40dp"
        android:top="40dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#334155" />
        </shape>
    </item>
    <item
        android:bottom="60dp"
        android:left="60dp"
        android:right="60dp"
        android:top="60dp">
        <shape android:shape="oval">
            <stroke
                android:width="4dp"
                android:color="#475569" />
        </shape>
    </item>
</layer-list>
