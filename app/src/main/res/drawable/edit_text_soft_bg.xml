<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#F5F9F9" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="@color/medical_teal" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/medical_grey_light" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#E0E8E8" />
        </shape>
    </item>
</selector>
