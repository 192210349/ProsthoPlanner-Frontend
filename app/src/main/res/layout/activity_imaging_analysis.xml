<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/welcome_bg"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imaging Analysis"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI powered diagnostic insights"
                android:textColor="@color/text_grey"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/secondaryActions"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Patient Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_profile_circle"
                        app:tint="@color/primary_teal"/>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        
                        <TextView
                            android:id="@+id/tvPatientName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                            
                        <TextView
                            android:id="@+id/tvCaseId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Case ID: #PP-89234"
                            android:textColor="@color/text_grey"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Imaging Visualization Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Diagnostic Visualization"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@color/white">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <ImageView
                        android:id="@+id/ivScanPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/welcome_graphic"
                        android:alpha="0.9" />

                    <!-- Premium Scrim Overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_card"
                        android:alpha="0.05" />
                    
                    <!-- Glassmorphism Controls Overlay -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="16dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#B30F172A"
                        android:padding="6dp">
                        
                        <ImageButton
                            android:id="@+id/btnZoom"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_search"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/white"/>
                            
                        <View android:layout_width="1dp" android:layout_height="24dp" android:background="#40FFFFFF" android:layout_gravity="center_vertical" android:layout_marginHorizontal="4dp"/>

                        <ImageButton
                            android:id="@+id/btnMarker"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_add_case"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <!-- AI Status Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#B310B981"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="AI ACTIVE"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- AI Analysis Cards Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="AI Insights"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Skeleton Content (Initially Visible, then hidden) -->
            <LinearLayout
                android:id="@+id/skeletonLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Simple Skeleton item -->
                <View android:layout_width="match_parent" android:layout_height="80dp" android:background="@drawable/card_premium_white" android:layout_marginTop="12dp" android:alpha="0.5"/>
                <View android:layout_width="match_parent" android:layout_height="80dp" android:background="@drawable/card_premium_white" android:layout_marginTop="12dp" android:alpha="0.5"/>
            </LinearLayout>

            <!-- Real Cards (Initially Hidden) -->
            <GridLayout
                android:id="@+id/cardsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="1"
                android:useDefaultMargins="false">

                <!-- Helper Card Macro could be used if programmatic, but XML direct for now -->
                <!-- Bone Height Card -->
                <include
                    android:id="@+id/cardBoneHeight"
                    layout="@layout/layout_analysis_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- Bone Width Card -->
                <include
                    android:id="@+id/cardBoneWidth"
                    layout="@layout/layout_analysis_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- Bone Density Card -->
                <include
                    android:id="@+id/cardBoneDensity"
                    layout="@layout/layout_analysis_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- Implant Site Recommendation -->
                <include
                    android:id="@+id/cardImplantSite"
                    layout="@layout/layout_analysis_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- Risk Level Card Special -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRiskLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/stat_emerald">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        
                        <ImageView
                            android:id="@+id/ivRiskIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_success_circle"
                            app:tint="@color/stat_emerald_text"/>
                            
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Risk Level"
                                android:textColor="@color/stat_emerald_text"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                                
                            <TextView
                                android:id="@+id/tvRiskValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Low Surgical Risk"
                                android:textColor="@color/stat_emerald_text"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Secondary Actions Row -->
    <LinearLayout
        android:id="@+id/secondaryActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="#F8FAFB"
        app:layout_constraintBottom_toTopOf="@id/bottomActions">

        <Button
            android:id="@+id/btnViewBoneMeasurement"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/btn_secondary"
            android:text="Bone Measures"
            android:textAllCaps="false"
            android:textColor="@color/primary_teal"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnViewSimulation"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_secondary"
            android:text="Simulation"
            android:textAllCaps="false"
            android:textColor="@color/primary_teal"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/white"
        android:elevation="16dp">

        <Button
            android:id="@+id/btnBackReview"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_secondary"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/text_grey"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnNextStep"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.8"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_primary"
            android:text="Continue"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
