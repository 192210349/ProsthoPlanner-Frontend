<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    android:fitsSystemWindows="true">

    <!-- Premium Header Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerPatients"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNotificationPatients"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvHeaderTitlePatients"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patients History"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="REVIEW AND MANAGE CLINICAL CASES"
                android:textColor="@color/accent_cyan"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnNotificationPatients"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_circle_premium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_notification_bell"
                app:tint="@color/accent_cyan" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search and Filter Area -->
    <LinearLayout
        android:id="@+id/filterAreaPatients"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerPatients">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/glass_card_premium"
            android:paddingHorizontal="20dp">
            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/accent_cyan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Search patients or ID..."
                android:textColorHint="#99E0F2F1"
                android:paddingStart="16dp"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:singleLine="true"
                app:layout_constraintStart_toEndOf="@id/ivSearchIcon"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="12dp"
                android:paddingEnd="24dp">
                
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Cases"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:checked="true"
                    app:chipBackgroundColor="@color/accent_cyan"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:chipCornerRadius="20dp"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Active Cases"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="#1AFFFFFF"
                    app:chipStrokeColor="#33FFFFFF"
                    app:chipStrokeWidth="1dp"
                    android:textColor="#E0F2F1"
                    android:textSize="13sp"
                    app:chipCornerRadius="20dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Completed"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="#1AFFFFFF"
                    app:chipStrokeColor="#33FFFFFF"
                    app:chipStrokeWidth="1dp"
                    android:textColor="#E0F2F1"
                    android:textSize="13sp"
                    app:chipCornerRadius="20dp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Patients List Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/rvPatientsScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterAreaPatients">

        <LinearLayout
            android:id="@+id/llPatients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/viewEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNavPatients"
        app:layout_constraintTop_toBottomOf="@id/filterAreaPatients">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/glass_circle_premium">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="40dp"
                android:src="@drawable/ic_single_tooth"
                app:tint="@color/accent_cyan"
                android:alpha="0.4" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="No Cases Found"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Your clinical cases will appear here once you start a new analysis."
            android:textColor="#E0F2F1"
            android:alpha="0.7"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartNewCaseEmpty"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="48dp"
            android:text="Start New Analysis"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="20dp"
            android:background="@drawable/btn_login_premium"
            app:backgroundTint="@null"
            app:elevation="8dp" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNavPatients"
        layout="@layout/layout_bottom_nav_premium"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
