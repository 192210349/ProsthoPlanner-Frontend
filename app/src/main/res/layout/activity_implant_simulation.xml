<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/welcome_bg"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Implant Simulation"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Patient Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_profile_circle"
                        app:tint="@color/primary_teal"/>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        
                        <TextView
                            android:id="@+id/tvPatientName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                            
                        <TextView
                            android:id="@+id/tvSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Case #PP-89234 • Site #46"
                            android:textColor="@color/text_grey"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Simulation Area -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/hero_card_bg">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <ImageView
                        android:id="@+id/ivJawModel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/welcome_graphic"
                        android:alpha="0.4"/>
                        
                    <!-- Bone Depth Overlay -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="200dp"
                        android:background="@drawable/card_premium_teal_outline"
                        android:layout_gravity="center"
                        android:alpha="0.3"/>
                        
                    <!-- Implant Marker -->
                    <ImageView
                        android:id="@+id/ivImplantMarker"
                        android:layout_width="40dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_single_tooth" />
                        
                    <!-- Crosshair/Guide -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary_teal"
                        android:layout_gravity="center_vertical"
                        android:alpha="0.2"/>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary_teal"
                        android:layout_gravity="center_horizontal"
                        android:alpha="0.2"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tools Panel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Simulation Controls"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    
                    <!-- Diameter -->
                    <TextView
                        android:id="@+id/tvDiameterLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diameter: 4.5 mm"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderDiameter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="3.0"
                        android:valueTo="6.0"
                        android:value="4.5"
                        app:thumbColor="@color/primary_teal"
                        app:trackColorActive="@color/primary_teal" />
                        
                    <!-- Length -->
                    <TextView
                        android:id="@+id/tvLengthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Length: 11.5 mm"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderLength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="8.0"
                        android:valueTo="15.0"
                        android:value="11.5"
                        app:thumbColor="@color/primary_teal"
                        app:trackColorActive="@color/primary_teal" />
                        
                    <!-- Angle -->
                    <TextView
                        android:id="@+id/tvAngleLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Angle: 0°"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"/>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderAngle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="-30.0"
                        android:valueTo="30.0"
                        android:value="0.0"
                        app:thumbColor="@color/primary_teal"
                        app:trackColorActive="@color/primary_teal" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Results Panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bone Contact"
                            android:textColor="@color/text_grey"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvBoneContact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="86%"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/stat_emerald">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stability"
                            android:textColor="@color/stat_emerald_text"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvStability"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High"
                            android:textColor="@color/stat_emerald_text"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/white"
        android:elevation="16dp">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_secondary"
            android:text="Save"
            android:textAllCaps="false"
            android:textColor="@color/text_grey"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnGeneratePlan"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.3"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/btn_secondary"
            android:text="Gen Plan"
            android:textAllCaps="false"
            android:textColor="@color/primary_teal"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.3"
            android:layout_marginStart="4dp"
            android:background="@drawable/btn_primary"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
