<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Top Navigation Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <ImageButton
            android:id="@+id/btnEditTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_case"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:tint="@color/accent_cyan"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Profile Hero Section -->
    <LinearLayout
        android:id="@+id/heroSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <androidx.cardview.widget.CardView
            android:id="@+id/avatarContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="16dp"
            android:background="@drawable/logo_container_premium"
            app:cardBackgroundColor="@android:color/transparent">
            
            <ImageView
                android:id="@+id/ivDoctorAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_profile_circle"
                app:tint="@color/accent_cyan" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="sarah johnson"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Senior Prosthodontist"
            android:textColor="@color/accent_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:id="@+id/badgeVerified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_badge_verified"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:elevation="4dp"
            android:gravity="center">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_verified"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Verified Doctor"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content Scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Professional Details Card -->
            <LinearLayout
                android:id="@+id/professionalCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_premium"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Professional Details"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="24dp" />

                <!-- Detail Rows -->
                <LinearLayout android:id="@+id/rowName" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_profile_circle" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Full Name" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sarah Johnson" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

                <LinearLayout android:id="@+id/rowEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_email" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Email ID" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailEmail" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="sarah.j@clinic.com" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

                <LinearLayout android:id="@+id/rowPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_phone" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Phone" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailPhone" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+91 98765 43210" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

                <LinearLayout android:id="@+id/rowQual" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_qualification" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Qualification" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailQual" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="MDS, BDS" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

                <LinearLayout android:id="@+id/rowSpec" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_single_tooth" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Specialty" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailSpec" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Prosthodontics" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

                <LinearLayout android:id="@+id/rowExp" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="12dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_experience" app:tint="@color/accent_cyan" />
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Experience" android:textColor="#B0BEC5" android:textSize="14sp" />
                    <TextView android:id="@+id/tvDetailExp" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="12 Years" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Quick Actions Section Header -->
            <TextView
                android:id="@+id/tvQuickActionsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Quick Actions"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp" />

            <!-- Quick Actions List -->
            <LinearLayout
                android:id="@+id/quickActionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/glass_card_premium"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <LinearLayout android:id="@+id/actionEdit" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_profile_circle" style="@style/ProfileIconBadge" app:tint="@color/accent_cyan" />
                    <TextView android:text="Edit Profile" style="@style/ProfileTextMain" android:textColor="@color/white" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="@color/white" android:rotation="180" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="20dp" />

                <LinearLayout android:id="@+id/actionPassword" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_lock" style="@style/ProfileIconBadge" app:tint="@color/accent_cyan" />
                    <TextView android:text="Change Password" style="@style/ProfileTextMain" android:textColor="@color/white" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="@color/white" android:rotation="180" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="20dp" />

                <LinearLayout android:id="@+id/actionPrivacy" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_security" style="@style/ProfileIconBadge" app:tint="@color/accent_cyan" />
                    <TextView android:text="Privacy &amp; Terms" style="@style/ProfileTextMain" android:textColor="@color/white" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="@color/white" android:rotation="180" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="20dp" />

                <LinearLayout android:id="@+id/actionAbout" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_home" style="@style/ProfileIconBadge" app:tint="@color/accent_cyan" />
                    <TextView android:text="About App" style="@style/ProfileTextMain" android:textColor="@color/white" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="@color/white" android:rotation="180" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="20dp" />

                <LinearLayout android:id="@+id/actionLogout" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_profile_circle" style="@style/ProfileIconBadge" app:tint="#FF5252" />
                    <TextView android:text="Logout" style="@style/ProfileTextMain" android:textColor="#FF5252" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="#FF5252" android:rotation="180" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginHorizontal="20dp" />

                <LinearLayout android:id="@+id/actionDelete" style="@style/ProfileActionRow">
                    <ImageView android:src="@drawable/ic_lock" style="@style/ProfileIconBadge" app:tint="#FF5252" />
                    <TextView android:text="Delete Account" style="@style/ProfileTextMain" android:textColor="#FF5252" />
                    <ImageView android:src="@drawable/ic_back" style="@style/ProfileArrow" app:tint="#FF5252" android:rotation="180" />
                </LinearLayout>
            </LinearLayout>

            <!-- App Version -->
            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="120dp"
                android:text="Version 2.4.0 (Build 912)"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav_premium"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
