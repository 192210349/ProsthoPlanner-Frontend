<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Premium Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackUpload"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitleUpload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Case"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/btnBackUpload"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBackUpload" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Premium Step Indicator Area -->
    <LinearLayout
        android:id="@+id/indicatorContainerUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/glass_card_premium"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerUpload">
        <include
            android:id="@+id/stepIndicatorUpload"
            layout="@layout/layout_step_indicator" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollUpload"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/bottomActionsUpload"
        app:layout_constraintTop_toBottomOf="@id/indicatorContainerUpload">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/tvUploadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imaging Upload"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/tvUploadSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Upload patient scans for AI analysis."
                android:textColor="#E0F2F1"
                android:textSize="15sp"
                android:alpha="0.8" />

            <!-- Patient Context Card -->
            <LinearLayout
                android:id="@+id/patientCardUpload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/glass_card_premium"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <ImageView
                    android:id="@+id/ivPatientIconUpload"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_profile_circle"
                    app:tint="@color/accent_cyan" />
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient Name"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvCaseId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Case ID: #PP-00000"
                        android:textColor="@color/accent_cyan"
                        android:alpha="0.9"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- OPG Upload Card -->
            <FrameLayout
                android:id="@+id/frameOpg"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_upload_dashed_premium">

                <LinearLayout
                    android:id="@+id/uploadUiOpg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/btnUploadOpg"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_upload_premium"
                        app:tint="@color/accent_cyan" />
                    <TextView
                        android:id="@+id/lblOpg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="OPG (Panoramic)"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvOpgStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tap to upload or drag file"
                        android:textColor="@color/accent_cyan"
                        android:alpha="0.7"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivOpgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="@drawable/glass_card_premium"
                    android:padding="2dp" />
            </FrameLayout>

            <!-- CBCT Upload Card -->
            <FrameLayout
                android:id="@+id/frameCbct"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_upload_dashed_premium">

                <LinearLayout
                    android:id="@+id/uploadUiCbct"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/btnUploadCbct"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_upload_premium"
                        app:tint="@color/accent_cyan" />
                    <TextView
                        android:id="@+id/lblCbct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="CBCT Scan"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvCbctStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tap to upload or drag file"
                        android:textColor="@color/accent_cyan"
                        android:alpha="0.7"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivCbctPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="@drawable/glass_card_premium"
                    android:padding="2dp" />
            </FrameLayout>

            <!-- Intraoral Photos Card -->
            <FrameLayout
                android:id="@+id/framePhotos"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_upload_dashed_premium">

                <LinearLayout
                    android:id="@+id/uploadUiPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/btnUploadPhotos"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_upload_premium"
                        app:tint="@color/accent_cyan" />
                    <TextView
                        android:id="@+id/lblPhotos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Intraoral Photos"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvPhotosStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tap to upload or drag file"
                        android:textColor="@color/accent_cyan"
                        android:alpha="0.7"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivPhotosPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="@drawable/glass_card_premium"
                    android:padding="2dp" />
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActionsUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="#1AFFFFFF"
        android:elevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnBackUploadStep"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/glass_edittext_bg"
            android:text="Back"
            android:textAllCaps="true"
            android:textColor="#B0BEC5"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnStartAi"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1.6"
            android:layout_marginStart="12dp"
            android:background="@drawable/btn_login_premium"
            android:text="Next Step"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:elevation="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
