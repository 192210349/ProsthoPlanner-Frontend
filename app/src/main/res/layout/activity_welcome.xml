<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    android:fitsSystemWindows="true">

    <!-- Massive Glowing Logo Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/logoContainer"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/glass_circle_premium"
        android:elevation="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/welcomeIcon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:elevation="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Neon Aura Glow View -->
        <View
            android:id="@+id/logoAura"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:alpha="0.25"
            android:background="@drawable/glass_circle_premium"
            android:backgroundTint="@color/accent_cyan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
            
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Sequence -->
    <LinearLayout
        android:id="@+id/llWelcomeContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/logoContainer">

        <TextView
            android:id="@+id/welcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:text="ProsthoPlanner"
            android:textColor="@color/white"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/welcomeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.08"
            android:text="AI-POWERED PROSTHODONTIC PLANNING"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/welcomeDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:paddingHorizontal="24dp"
            android:text="Elevate clinical decisions with advanced AI insights, precise planning, and comprehensive management."
            android:textColor="#E0F2F1"
            android:alpha="0.85"
            android:textSize="14sp" />
            
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/llWelcomeActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/btn_login_premium"
            android:fontFamily="sans-serif-black"
            android:text="Sign In"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@null"
            android:elevation="8dp" />

        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/btn_welcome_secondary"
            android:fontFamily="sans-serif-black"
            android:text="Create Account"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@null" />
            
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
