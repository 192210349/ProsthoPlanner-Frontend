<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingVertical="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Step 1 Dot (Active) -->
        <View
            android:id="@+id/dotStep1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/circle_indicator_active"
            android:backgroundTint="@color/accent_cyan"
            android:elevation="6dp" />

        <View
            android:id="@+id/lineStep1to2"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="#33D3EE"
            android:alpha="0.3" />

        <!-- Step 2 Dot -->
        <View
            android:id="@+id/dotStep2"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator_inactive"
            android:backgroundTint="#4DFFFFFF" />

        <View
            android:id="@+id/lineStep2to3"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="#4DFFFFFF"
            android:alpha="0.2" />

        <!-- Step 3 Dot -->
        <View
            android:id="@+id/dotStep3"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator_inactive"
            android:backgroundTint="#4DFFFFFF" />

        <View
            android:id="@+id/lineStep3to4"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="#4DFFFFFF"
            android:alpha="0.2" />

        <!-- Step 4 Dot -->
        <View
            android:id="@+id/dotStep4"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator_inactive"
            android:backgroundTint="#4DFFFFFF" />

        <View
            android:id="@+id/lineStep4to5"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="#4DFFFFFF"
            android:alpha="0.2" />

        <!-- Step 5 Dot -->
        <View
            android:id="@+id/dotStep5"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator_inactive"
            android:backgroundTint="#4DFFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvStepLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Step 1: Patient Information"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.05"
        android:textAllCaps="true" />

</LinearLayout>
