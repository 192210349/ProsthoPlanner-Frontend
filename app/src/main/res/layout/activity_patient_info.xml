<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Premium Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Case"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Premium Step Indicator Area -->
    <LinearLayout
        android:id="@+id/indicatorContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/glass_card_premium"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/header">
        <include
            android:id="@+id/stepIndicator"
            layout="@layout/layout_step_indicator" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toBottomOf="@id/indicatorContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Information"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/tvFormSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Fill in patient details to register the case."
                android:textColor="#E0F2F1"
                android:textSize="15sp"
                android:alpha="0.8" />

            <!-- Main Form Card -->
            <LinearLayout
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/glass_card_premium"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="8dp">

                <!-- Full Name -->
                <TextView
                    android:id="@+id/lblFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL NAME"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />
                
                <EditText
                    android:id="@+id/etPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/glass_edittext_bg"
                    android:hint="Patient's Full Name"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="16sp" />

                <!-- Age and Gender Grid -->
                <LinearLayout
                    android:id="@+id/gridAgeGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/lblAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AGE"
                            android:textColor="@color/accent_cyan"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp" />
                        <EditText
                            android:id="@+id/etPatientAge"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="@drawable/glass_edittext_bg"
                            android:hint="25"
                            android:inputType="number"
                            android:paddingHorizontal="24dp"
                            android:textColor="@color/white"
                            android:textColorHint="#80FFFFFF"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/lblGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GENDER"
                            android:textColor="@color/accent_cyan"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp" />
                        <Spinner
                            android:id="@+id/spinnerGender"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="@drawable/glass_edittext_bg"
                            android:paddingHorizontal="16dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Mobile Number -->
                <TextView
                    android:id="@+id/lblMobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="MOBILE NUMBER"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />
                
                <EditText
                    android:id="@+id/etPatientMobile"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/glass_edittext_bg"
                    android:hint="+91 00000 00000"
                    android:inputType="phone"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="16sp" />

                <!-- Patient ID (Optional) -->
                <TextView
                    android:id="@+id/lblPatientId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="PATIENT ID (OPTIONAL)"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />
                
                <EditText
                    android:id="@+id/etPatientId"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/glass_edittext_bg"
                    android:hint="P-123456"
                    android:inputType="text"
                    android:paddingHorizontal="24dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="#1AFFFFFF"
        android:elevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/glass_edittext_bg"
            android:text="Cancel"
            android:textAllCaps="true"
            android:textColor="#B0BEC5"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1.6"
            android:layout_marginStart="12dp"
            android:background="@drawable/btn_login_premium"
            android:text="Next Step"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:elevation="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
