<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/welcome_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Clinic Setup"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.6"
            android:text="Register your clinic to start managing cases with a professional presence"
            android:textColor="@color/text_grey"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <!-- Clinic Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Clinic Name"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etClinicName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/edit_text_premium_bg"
                android:hint="e.g. Healthy Smiles Clinic"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black" />

            <!-- License Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Medical License Number"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etLicenseNumber"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/edit_text_premium_bg"
                android:hint="License ID"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black" />

            <!-- Clinic Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Clinic Address"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etClinicAddress"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/edit_text_premium_bg"
                android:gravity="top|start"
                android:hint="Street, Area, etc."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/black" />

            <!-- City and Country Group -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="City"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etCity"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edit_text_premium_bg"
                        android:hint="City"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Country"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etCountry"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/edit_text_premium_bg"
                        android:hint="Country"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/black" />
                </LinearLayout>
            </LinearLayout>

            <!-- Hospital / Institution -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Hospital / Institution"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etHospital"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/edit_text_premium_bg"
                android:hint="Associated Hospital"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black" />

            <!-- Consultation Fee -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Consultation Fee (Optional)"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etConsultationFee"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/edit_text_premium_bg"
                android:hint="e.g. 500"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black" />

        </LinearLayout>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/btn_primary"
            android:text="Complete Setup"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/formContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
