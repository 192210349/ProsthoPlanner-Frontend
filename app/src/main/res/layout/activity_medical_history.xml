<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient">

    <!-- Premium Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Case"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/btnBackTop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBackTop" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Premium Step Indicator Area -->
    <LinearLayout
        android:id="@+id/indicatorArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/glass_card_premium"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/header">
        <include
            android:id="@+id/stepIndicatorView"
            layout="@layout/layout_step_indicator" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMedical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toBottomOf="@id/indicatorArea">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tvMedicalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical History"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/tvMedicalSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Record systemic conditions and social habits."
                android:textColor="#E0F2F1"
                android:textSize="15sp"
                android:alpha="0.8" />

            <!-- Systemic Conditions Header -->
            <TextView
                android:id="@+id/tvSystemicHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="SYSTEMIC CONDITIONS"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupConditions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:chipSpacingHorizontal="12dp"
                app:chipSpacingVertical="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDiabetes"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diabetes"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipIconEnabled="false"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHypertension"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hypertension"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipThyroid"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thyroid Issues"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAsthma"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asthma"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipCornerRadius="16dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Social Habits Section -->
            <TextView
                android:id="@+id/tvSocialHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="SOCIAL HABITS"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupHabits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:chipSpacingHorizontal="12dp"
                app:chipSpacingVertical="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSmoking"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smoking"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAlcohol"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alcohol"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/glass_chip_bg_csl"
                    app:chipStrokeColor="@color/glass_chip_stroke_csl"
                    app:chipStrokeWidth="1dp"
                    app:rippleColor="#3322D3EE"
                    app:chipCornerRadius="16dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Allergies and Medications Card -->
            <LinearLayout
                android:id="@+id/formCardMedical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/glass_card_premium"
                android:orientation="vertical"
                android:padding="24dp"
                android:elevation="8dp">

                <TextView
                    android:id="@+id/lblAllergies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALLERGIES (IF ANY)"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />
                
                <EditText
                    android:id="@+id/etAllergies"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/glass_edittext_bg"
                    android:gravity="top"
                    android:hint="List drug, food, or material allergies..."
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lblMedications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="CURRENT MEDICATIONS"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />
                
                <EditText
                    android:id="@+id/etMedications"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/glass_edittext_bg"
                    android:gravity="top"
                    android:hint="Specify current medications and dosage..."
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:textColor="@color/white"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="#1AFFFFFF"
        android:elevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnBackStep"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/glass_edittext_bg"
            android:text="Back"
            android:textAllCaps="true"
            android:textColor="#B0BEC5"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1.6"
            android:layout_marginStart="12dp"
            android:background="@drawable/btn_login_premium"
            android:text="Next Step"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:elevation="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
