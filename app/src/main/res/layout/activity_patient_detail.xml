<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    android:fitsSystemWindows="true">

    <!-- Premium Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnBackDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_circle_premium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvTitleDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient Summary"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/btnBackDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBackDetail" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnOptionsDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_circle_premium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_profile_circle"
                app:tint="@color/accent_cyan" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDetail"
        app:layout_constraintTop_toBottomOf="@id/headerDetail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <!-- World-Class Patient Hero Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/heroCardDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_premium"
                android:padding="28dp"
                android:elevation="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/heroAvatarContainer"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/glass_circle_premium"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:src="@drawable/ic_profile_circle"
                        app:tint="@color/accent_cyan" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/heroAvatarContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/heroAvatarContainer"
                    app:layout_constraintTop_toTopOf="@id/heroAvatarContainer">

                    <TextView
                        android:id="@+id/tvPatientNameDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Doe"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvCaseIdDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="CASE ID: #PP99283"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#1A00E5FF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="AI PROCESSED"
                            android:textColor="@color/accent_cyan"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="#1AFFFFFF"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="PLAN ACTIVE"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.08" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Status Grid -->
            <TextView
                android:id="@+id/tvStatusTitleDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="CLINICAL DIAGNOSTICS"
                android:textColor="@color/accent_cyan"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12" />

            <GridLayout
                android:id="@+id/gridDiagnosticsDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Imaging Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/glass_card_premium"
                    android:padding="20dp">
                    <ImageView
                        android:id="@+id/ivImagingDetail"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_imaging"
                        app:tint="@color/accent_cyan"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="IMAGING"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        app:layout_constraintTop_toBottomOf="@id/ivImagingDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="3 Files"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintTop_toBottomOf="@id/ivImagingDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Bone Density Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/glass_card_premium"
                    android:padding="20dp">
                    <ImageView
                        android:id="@+id/ivBoneDetail"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_single_tooth"
                        app:tint="@color/accent_cyan"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="BONE DEN."
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        app:layout_constraintTop_toBottomOf="@id/ivBoneDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="High Qual."
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintTop_toBottomOf="@id/ivBoneDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Risk Level Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/glass_card_premium"
                    android:padding="20dp">
                    <ImageView
                        android:id="@+id/ivRiskDetail"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_analytics"
                        app:tint="@color/accent_cyan"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="RISK LEVEL"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        app:layout_constraintTop_toBottomOf="@id/ivRiskDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="Low (Safe)"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintTop_toBottomOf="@id/ivRiskDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Last Visit Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/glass_card_premium"
                    android:padding="20dp">
                    <ImageView
                        android:id="@+id/ivVisitDetail"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_security"
                        app:tint="@color/white"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="LAST VISIT"
                        android:textColor="@color/accent_cyan"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        app:layout_constraintTop_toBottomOf="@id/ivVisitDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="OCT 24, 26"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintTop_toBottomOf="@id/ivVisitDetail"
                        app:layout_constraintStart_toStartOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </GridLayout>

            <!-- Tiered Clinical Summary Block -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/summaryBlockDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/glass_card_premium"
                android:padding="28dp"
                android:elevation="4dp">
                <TextView
                    android:id="@+id/tvSummaryTitleDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLINICAL ASSESSMENT SUMMARY"
                    android:textColor="@color/accent_cyan"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
                <TextView
                    android:id="@+id/tvClinicalSummaryDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Patient presents with generalized bone loss in the posterior mandible. AI suggests single tooth implant for site #36. Overall oral hygiene is satisfactory. No significant medical contraindications for the proposed procedure."
                    android:textColor="#E0F2F1"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingExtra="6dp"
                    android:alpha="0.9"
                    app:layout_constraintTop_toBottomOf="@id/tvSummaryTitleDetail"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom CTA Button -->
            <Button
                android:id="@+id/btnOpenCaseCommandDetail"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/btn_login_premium"
                android:text="Open Case Command Center"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                android:elevation="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNavDetail"
        layout="@layout/layout_bottom_nav_premium"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
